{
  "name": "pdftool-work",
  "version": "1.0.0",
  "private": true,
  "description": "pdftool.work static client-side PDF tools",
  "scripts": {
    "build": "npm run build:css && node scripts/copy-vendor.mjs",
    "build:css": "tailwindcss -i ./src/tailwind.css -o ./assets/css/tailwind.min.css --minify",
    "watch:css": "tailwindcss -i ./src/tailwind.css -o ./assets/css/tailwind.min.css --watch",
    "serve": "python -m http.server 8080"
  },
  "dependencies": {
    "pdf-lib": "1.17.1"
  },
  "devDependencies": {
    "tailwindcss": "3.4.17"
  }
}
